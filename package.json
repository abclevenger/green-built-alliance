{
  "name": "greenbuilt-migration",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "crawl": "node scripts/crawl.mjs",
    "crawl:pages": "node scripts/crawl.mjs --url-list=page-urls.txt",
    "crawl:posts": "node scripts/crawl.mjs --url-list=post-urls.txt --skip-existing",
    "crawl:events": "node scripts/crawl.mjs --url-list=event-urls.txt --skip-existing",
    "route-map": "node scripts/generate-route-map.mjs",
    "asset-inventory": "node scripts/asset-inventory.mjs",
    "audit:second-pass": "node scripts/audit-second-pass.mjs --scan-links=all --spot-check=40",
    "crawl:discovered": "node scripts/crawl-all-discovered.mjs --rounds=12 --max-per-round=500",
    "authors:generate": "node scripts/generate-author-urls.mjs",
    "patch:home-perf": "node scripts/patch-homepage-performance.mjs"
  },
  "dependencies": {
    "cheerio": "^1.2.0",
    "next": "16.2.0",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
